# gr33n API server configuration (tracked — local dev reference, no secrets)
#
# Put JWT_SECRET, PI_API_KEY, and other machine secrets in `.env.local` (gitignored).
# The API loads `.env` then `.env.local` from the repo root.
# Real process env vars always override these files.

DATABASE_URL=postgres://gr33n:gr33n@127.0.0.1:5433/gr33n?sslmode=disable
PORT=8080

# AUTH_MODE: dev | auth_test | production (default: production)
#
# dev — JWT + Pi key checks skipped. Requires `-tags dev` (see Makefile run/dev).
# auth_test — same enforcement as production, but only allowed on `-tags dev`
#   binaries (docker/prod images refuse this mode). Use for local login regression.
# production — full auth. Default when unset.
#
# Examples:
#   make run / make dev              → AUTH_MODE=dev
#   make run-auth-test               → AUTH_MODE=auth_test + set secrets below
#   go build ./cmd/api               → never use dev or auth_test in deployed images
AUTH_MODE=auth_test

# Required when AUTH_MODE is auth_test or production — set real values in .env.local
JWT_SECRET=change-me-to-a-long-random-string
PI_API_KEY=change-me-to-a-shared-secret

CORS_ORIGIN=http://localhost:5173

ADMIN_USERNAME=admin
# Optional: only if not using ~/.gr33n/admin.hash (main prefers the file).
# bcrypt: htpasswd -nbBC 10 "" 'password' | cut -d: -f2   OR   echo -n 'password' | go run scripts/gen-admin-hash.go
ADMIN_PASSWORD_HASH=

# Env-admin JWT claims (must match a real user + farm membership — defaults = master_seed demo user).
ADMIN_BIND_USER_ID=00000000-0000-0000-0000-000000000001
ADMIN_BIND_EMAIL=dev@gr33n.local

# Automation worker
AUTOMATION_SIMULATION_MODE=true
AUTOMATION_COOLDOWN_SECONDS=60

# Farm Guardian chat (Ollama on localhost — see docs/farm-guardian-ollama-setup.md)
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=phi3:mini
LLM_TIMEOUT_SECONDS=2100
LLM_RETRY_MAX_ATTEMPTS=1

# RAG embeddings (Ollama OpenAI-compatible — Phase 37 field_guide + platform_doc)
# Override in `.env.local` if your provider uses a real API key.
EMBEDDING_API_KEY=local-dev-key
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=rjmalagon/gte-qwen2-1.5b-instruct-embed-f16
EMBEDDING_TIMEOUT_SECONDS=600
GUARDIAN_GROUNDED_TIMEOUT_SECONDS=2400
GUARDIAN_EVAL_TIMEOUT_SECONDS=2700

# Phase 145 — answer relevance / topic drift (embed cosine; turn debug + smoke eval)
GUARDIAN_RELEVANCE_MIN=0.35

# Online weather forecast (Phase 178) — Open-Meteo is free, no API key
WEATHER_PROVIDER=openmeteo
