# gr33n API server configuration
# Copy to .env and adjust values for your environment.

DATABASE_URL=postgres://user:password@localhost:5432/gr33n?sslmode=disable
PORT=8080

# "dev" disables JWT + API-key checks; "production" enforces both
AUTH_MODE=dev

# Required when AUTH_MODE=production
JWT_SECRET=change-me-to-a-long-random-string
PI_API_KEY=change-me-to-a-shared-secret

CORS_ORIGIN=http://localhost:5173

ADMIN_USERNAME=admin
# bcrypt hash — generate with: htpasswd -nbBC 10 "" 'yourpassword' | cut -d: -f2
ADMIN_PASSWORD_HASH=

# Automation worker
AUTOMATION_SIMULATION_MODE=true
AUTOMATION_COOLDOWN_SECONDS=60
