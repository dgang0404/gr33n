# gr33n API server configuration
#
# Copy to `.env` (gitignored) and set values once. The API loads `.env` then `.env.local`
# automatically when you start it from the repo root — no need to export secrets every session.
# Real process env vars always override these files.

# Pick ONE that matches how you run Postgres (compose vs native); wrong URL → API offline / auth errors.
# Docker Compose db (published on host 5433 — see docker-compose.yml):  postgres://gr33n:gr33n@127.0.0.1:5433/gr33n?sslmode=disable
# Native Linux peer auth (same OS user as Postgres role):  postgres:///gr33n?host=/var/run/postgresql
# TCP example (replace user/password):  postgres://user:password@localhost:5433/gr33n?sslmode=disable
DATABASE_URL=postgres://user:password@localhost:5433/gr33n?sslmode=disable
PORT=8080

# AUTH_MODE: dev | auth_test | production (default: production)
#
# dev — JWT + Pi key checks skipped. Requires `-tags dev` (see Makefile run/dev).
# auth_test — same enforcement as production, but only allowed on `-tags dev`
#   binaries (docker/prod images refuse this mode). Use for local login regression.
# production — full auth. Default when unset.
#
# Examples:
#   make run / make dev              → AUTH_MODE=dev
#   make run-auth-test               → AUTH_MODE=auth_test + set secrets below
#   go build ./cmd/api               → never use dev or auth_test in deployed images
AUTH_MODE=dev

# Required when AUTH_MODE is auth_test or production
JWT_SECRET=change-me-to-a-long-random-string
PI_API_KEY=change-me-to-a-shared-secret

CORS_ORIGIN=http://localhost:5173

# Optional: API request logs (slog) — see docs/operator-troubleshooting.md
# LOG_FORMAT=json
# AUTH_DEBUG_LOG=true

ADMIN_USERNAME=admin
# bcrypt hash for env-admin — optional if you use ~/.gr33n/admin.hash instead (main.go prefers the file).
# Generate: htpasswd -nbBC 10 "" 'yourpassword' | cut -d: -f2   OR   echo -n 'yourpassword' | go run scripts/gen-admin-hash.go
ADMIN_PASSWORD_HASH=

# Env-admin (ADMIN_USERNAME + admin.hash): JWT must carry user_id or farm routes return 401.
# Defaults match db/seeds/master_seed.sql (demo user owns farm_id=1).
ADMIN_BIND_USER_ID=00000000-0000-0000-0000-000000000001
ADMIN_BIND_EMAIL=dev@gr33n.local

# Automation worker
AUTOMATION_SIMULATION_MODE=true
AUTOMATION_COOLDOWN_SECONDS=60

# rag-ingest CLI (Phase 24/25 — not loaded by cmd/api unless you export them)
# DATABASE_URL must point at pgvector-enabled Postgres. EMBEDDING_* call your embedding provider.
# Phase 84 — platform catalog + field guides in Postgres (default db; yaml/file = legacy authoring)
CROP_CATALOG_SOURCE=db
AGRONOMY_FIELD_GUIDES_SOURCE=db
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=
# Optional incremental watermark for cron (RFC3339 / RFC3339Nano). Overrides empty -updated-after flag.
# RAG_INGEST_UPDATED_AFTER=2026-04-01T00:00:00Z

# RAG answer synthesis — POST /farms/{id}/rag/answer (cmd/api)
# Master switch (Phase 27): when false, disables synthesis and POST /v1/chat (Lite installs).
# When unset, defaults to ON so existing deployments keep working without a config change.
# AI_ENABLED=false
#
# HTTP timeout for OpenAI-compatible chat requests (default 666 seconds if unset).
LLM_TIMEOUT_SECONDS=666
#
# Phase 46 — Guardian LLM tool proposals (hybrid C). Matchers run first; on miss +
# write intent + Operate, assistant JSON may open a Confirm card when enabled.
# GUARDIAN_LLM_PROPOSALS=false
#
# Phase 48 — dev seed profiles (local/staging only). Default for dev-reset-farm.sh.
# DEV_SEED_PROFILE=small_indoor
#
# Optional Timescale retention for dev DB hygiene (run ./scripts/apply-dev-retention.sh).
# TIMESCALE_RETENTION_DAYS=90
#
# Optional: retry/backoff on transient LLM failures (Phase 27 WS3 follow-up).
# Total attempts including the first try (default 3, clamped 1..8). MaxAttempts=1 disables retry.
# Retryable: HTTP 408/425/429/5xx, per-attempt timeout, net errors. Not retried: context cancel,
# 4xx other than the above, mid-stream errors after the first delta has been forwarded.
# LLM_RETRY_MAX_ATTEMPTS=3
# Initial backoff in milliseconds (default 500, clamped 10..30000). Doubles per retry up to 10s
# with ±25% jitter so a fleet of clients doesn't thunder the LLM at the same instant.
# LLM_RETRY_BACKOFF_MS=500
#
# Optional: multimodal vision for Farm Guardian chat (Phase 30 WS6).
# Requires a vision-capable model (e.g. llava via Ollama). Zone photos use attachment_ids on POST /v1/chat.
# LLM_VISION_MODEL=llava
# LLM_VISION_BASE_URL=          # defaults to LLM_BASE_URL
# LLM_VISION_API_KEY=           # defaults to LLM_API_KEY
#
# Optional: TTL pruning for Farm Guardian conversation history (Phase 27 WS5 follow-up).
# Sessions whose newest turn is older than CHAT_SESSION_TTL_DAYS are dropped on a background
# loop. 0 disables the loop entirely (history grows forever). Default 30 days, clamp 0..3650.
# CHAT_SESSION_TTL_DAYS=30
# How often the prune loop runs (hours). Default 24, clamp 1..168 (one week).
# CHAT_SESSION_PRUNE_INTERVAL_HOURS=24
# Delay before the first prune at API startup (seconds). Default 30, clamp 0..600.
# Lets boot-time work (RAG ingest, automation worker) settle before we touch the chat tables.
# CHAT_SESSION_PRUNE_STARTUP_DELAY_SECONDS=30
#
# Optional: rolling-window cost guards on Farm Guardian chat token usage (Phase 27 WS5 follow-up).
# POST /v1/chat returns HTTP 429 (with Retry-After) once accumulated prompt_tokens + completion_tokens
# in the window exceed the configured cap. Both caps default to 0 (disabled) — set whichever you need.
# Use this to catch runaway loops or scripted abuse on multi-tenant deployments.
# Window length in hours, clamp 1..168 (one week). Default 1.
# CHAT_COST_WINDOW_HOURS=1
# Per-user cap: total tokens any single user is allowed across all their sessions in the window. 0 = off.
# CHAT_COST_MAX_TOKENS_PER_USER=0
# Per-farm cap: total tokens across all users for a given farm_id in the window. Only enforced when
# the chat request includes a farm_id (i.e. grounded turns). 0 = off.
# CHAT_COST_MAX_TOKENS_PER_FARM=0
#
# Default 30/minute process-wide. When PER_FARM is set (>0), each farm_id gets its own bucket (replaces global-only limiting).
# RAG_SYNTHESIS_MAX_PER_MINUTE=30
# RAG_SYNTHESIS_MAX_PER_MINUTE_PER_FARM=10
