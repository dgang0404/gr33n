# Copy to `.env.local` (gitignored) and set your machine secrets.
# The API loads `.env` then `.env.local` automatically from the repo root.
#
# Load into your shell:
#   source scripts/source-local-env.sh
# Refresh smoke JWT after login expiry:
#   source scripts/source-local-env.sh --refresh-eval-token

JWT_SECRET=change-me-to-a-long-random-string
PI_API_KEY=change-me-to-a-shared-secret

# Optional — same values as root `.env` embedding block if you override locally
# EMBEDDING_API_KEY=local-dev-key

# Optional — refreshed by source-local-env.sh --refresh-eval-token (expires)
# GUARDIAN_EVAL_TOKEN=

# Optional overrides (uncomment if needed):
# DATABASE_URL=postgres://gr33n:gr33n@127.0.0.1:5433/gr33n?sslmode=disable
