# Copy to /etc/default/gr33n-mqtt-bridge or export before starting the service.
# Paths are examples — adjust for your host.

GR33N_API_URL=https://gr33n-api.example.com
GR33N_FARM_ID=1
PI_API_KEY=replace-with-same-secret-as-api-PI_API_KEY

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASS=
# MQTT_USE_TLS=1
# MQTT_CA_FILE=/etc/ssl/certs/ca.crt

MQTT_SENSOR_MAP_PATH=/opt/gr33n/mqtt_bridge_map.yaml
# MQTT_TOPIC_PREFIX=gr33n
# Coalesce readings for N milliseconds (0 = one HTTP POST per MQTT message)
# MQTT_BATCH_MS=250

# LOG_LEVEL=INFO
