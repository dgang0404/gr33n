# Room-scale warehouse bridge — copy to /etc/default/gr33n-mqtt-bridge or export locally.
# See docs/mqtt-edge-operator-playbook.md § Room-scale warehouse pattern (Phase 31 WS4).

GR33N_API_URL=http://192.168.1.50:8080
GR33N_FARM_ID=1
PI_API_KEY=replace-with-same-secret-as-api-PI_API_KEY

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
# MQTT_USER=bridge
# MQTT_PASS=
# MQTT_USE_TLS=1

# Phase 31 WS4 — zone-centric topics for multi-shelf / multi-room warehouses
MQTT_TOPIC_LAYOUT=room
MQTT_TOPIC_PREFIX=gr33n
MQTT_SENSOR_MAP_PATH=/opt/gr33n/mqtt_bridge_map.room-scale.yaml

# Coalesce bursty MCU publishes → fewer HTTP POSTs (max 64 readings per batch)
MQTT_BATCH_MS=250

# Example publish (mosquitto_pub):
#   mosquitto_pub -t 'gr33n/farm/1/zone/2/sensor/par' -m '{"v":420}'
#   mosquitto_pub -t 'gr33n/farm/1/zone/2/sensor/1' -m '380.5'

# LOG_LEVEL=INFO
